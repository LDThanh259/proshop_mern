# Copy to /opt/proshop/.env on EC2 (or app-stack/.env for local).
# Do not commit real secrets.

# --- App (ProShop backend) ---
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://mongodb:27017/proshop
JWT_SECRET=change-me
PAYPAL_CLIENT_ID=

# --- HTTPS / Nginx (EC2 production) ---
DOMAIN=proshop-mern.duckdns.org

# --- Monitoring / Alertmanager ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Grafana (prod override) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# --- Deploy script ---
# RUN_SEED=true
# PROSHOP_DIR=/opt/proshop
